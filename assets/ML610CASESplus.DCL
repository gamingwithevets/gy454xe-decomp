;;*********************************************************
;;		DCL FILE for ML610CASESplus, Ver.1.00
;;*********************************************************

#CORE			"nX-U8/100"			;U16 wont be recognized
#REVISION		"A3"
#TARGET			"ML610CASESplus"
#VERSION		"1.00"

;+++++++++++++++++++++++++++++++++++++++++++++++++++++
;		MEMORY RANGE
;+++++++++++++++++++++++++++++++++++++++++++++++++++++
;Program memory space (physical segment #0)
#ROM	0H	,	0FFFFH
		SWI_VECTOR	00080H	,	000FFH
		CODE		00000H	,	0FFFFH

;Data memory space (physical segment #0)
#RAM	0H	,	0FFFFH
		DATA		08000H	,	08DFFH
		DATA		0F000H	,	0FFFFH
		INTERNALRAM	08000H	,	08DFFH
		SFR			0F000H	,	0FFFFH
;;					start_adr	end_adr		WINVAL
		ROMWINDOW	00000H	,	07FFFH	,	0FFH ; WINVAL is dummy

;;definition of physical segment #1 and over memory space

;; #EXTEND  cs_max, ds_max
;;	  cs_max : number of physical segment for Program memory
;;	  ds_max : number of physical segment for Data memory

#EXTEND	16	,	32
		ROM	01H:00000H	,	01H:0FFFFH
		ROM	08H:00000H	,	08H:0FFFFH

;+++++++++++++++++++++++++++++++++++++++++++++++++++++
;	   CODE ADDRESS SYMBOLS
;
;	   definition of CODE type symbols
;	   - SYNTAX -
;	   #DEFCODE
;			   Symbol  Code_Address
;			   ....................
;+++++++++++++++++++++++++++++++++++++++++++++++++++++

#DEFCODE
;+++++++++++++++++++++++++++++++++++++++++++++++++++++
;	   VECTOR AREA
;+++++++++++++++++++++++++++++++++++++++++++++++++++++
		WDTINT			0008H
		XI0INT			000AH
		XI1INT			000CH
		XI2INT			000EH
		XI3INT			0010H
		TM0INT			0012H
		L256SINT		0014H
		L1024SINT		0016H
		L4096SINT		0018H
		L16384SINT		001AH
		SIO0INT			001CH
		I2C0INT			001EH
		I2C1INT			0020H

