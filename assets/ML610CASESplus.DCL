;+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
;	   SFR ACCESS ATTRIBUTE DEFINITIONS
;
;	   - SYNTAX -
;	   #ACCESS
;  Data_Address:| Access_Unit |		Bit_Pattern		|
;   Address	 |   Word/Byte |   Read	  |	  Write  |
;   .......		 .........	 ....			 .....
;+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
#ACCESS
	DSR				:	--RW	0001_1111B	0000_0001B
	LTBADJL			:	RWRW	1111_1111B	1111_1111B
	LTBADJH			:	--RW	0000_0111B	0000_0111B
	STPACP			:	---W	-			-			
